      "updated": 1772103376525,
      "link": null,
      "locked": false,
      "text": "If something goes wrong here \n    -> might dispatch alert\n    -> socket_fd is terminated inside/after\nSSL_read()\n\n    ->  SSL_read could return -1 or 0 depending on\nerrors\n-> shutdown\n0: client closes connection cleanly (close_notify)\n-1: Error, can use SSL_get_error() to get error\n> 0 : number of bytes received",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If something goes wrong here \n    -> might dispatch alert\n    -> socket_fd is terminated inside/after SSL_read()\n\n    ->  SSL_read could return -1 or 0 depending on errors\n-> shutdown\n0: client closes connection cleanly (close_notify)\n-1: Error, can use SSL_get_error() to get error\n> 0 : number of bytes received",
      "autoResize": false,
      "lineHeight": 1.25
    },
